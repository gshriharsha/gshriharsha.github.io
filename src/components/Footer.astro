---
import { Icon } from 'astro-icon/components';
import { site } from '../data/site';

const year = new Date().getFullYear();
---
<footer class="border-t border-[color:var(--color-border)] bg-[color:var(--color-surface)]">
  <div class="mx-auto flex w-full max-w-[var(--max-content)] flex-col items-center justify-between gap-4 px-4 py-8 text-sm text-[color:var(--color-text-muted)] sm:flex-row sm:px-6 lg:px-8">
    <p>© {year} {site.name}. Built with <a href="https://astro.build" class="font-medium text-[color:var(--color-text)] hover:text-[color:var(--color-accent)]" target="_blank" rel="noopener noreferrer">Astro</a>.</p>
    <div class="flex items-center gap-3">
      <a href={site.links.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-bg)] px-3 py-1.5 transition hover:text-[color:var(--color-text)]">
        <Icon name="simple-icons:github" class="h-4 w-4" aria-hidden="true" />
        Source
      </a>
      <a href={site.links.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-bg)] px-3 py-1.5 transition hover:text-[color:var(--color-text)]">
        <Icon name="simple-icons:linkedin" class="h-4 w-4" aria-hidden="true" />
        LinkedIn
      </a>
    </div>
  </div>
</footer>
