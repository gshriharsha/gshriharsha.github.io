---
import { Icon } from 'astro-icon/components';
import { site } from '../data/site';
---
<section class="relative overflow-hidden">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-32 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full bg-[color:var(--color-accent)] opacity-10 blur-3xl"></div>
    <div class="absolute -bottom-40 right-0 h-[28rem] w-[28rem] rounded-full bg-[color:var(--color-accent)] opacity-5 blur-3xl"></div>
  </div>

  <div class="mx-auto flex w-full max-w-[var(--max-content)] flex-col items-start gap-6 px-4 py-24 sm:px-6 lg:px-8 lg:py-32">
    <span class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1 text-xs font-medium text-[color:var(--color-text-muted)]">
      <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
      {site.availability}
    </span>
    <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl lg:text-6xl">
      {site.name}
    </h1>
    <p class="text-lg font-medium text-[color:var(--color-text-muted)] sm:text-xl">
      {site.title} · <span class="text-[color:var(--color-accent)]">{site.tagline}</span>
    </p>
    <p class="max-w-[var(--max-prose)] text-base text-[color:var(--color-text-muted)] sm:text-lg">
      {site.summary}
    </p>
    <div class="mt-2 flex flex-wrap gap-3">
      <a href="#projects" class="inline-flex items-center gap-2 rounded-full bg-[color:var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-[color:var(--color-accent-hover)]">
        View work
        <Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
      </a>
      <a href={site.links.resume} class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-5 py-2.5 text-sm font-medium text-[color:var(--color-text)] transition hover:bg-[color:var(--color-surface-2)]">
        <Icon name="lucide:file-text" class="h-4 w-4" aria-hidden="true" />
        View resume
      </a>
      <a href={site.links.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-5 py-2.5 text-sm font-medium text-[color:var(--color-text)] transition hover:bg-[color:var(--color-surface-2)]">
        <Icon name="simple-icons:linkedin" class="h-4 w-4" aria-hidden="true" />
        LinkedIn
      </a>
    </div>
  </div>
</section>
